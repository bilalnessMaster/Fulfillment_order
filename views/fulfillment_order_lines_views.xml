<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fulfillment_order_lines_view_form" model="ir.ui.view">
        <field name="name">fulfillment.order.lines.form</field>
        <field name="model">fulfillment.order.lines</field>
        <field name="arch" type="xml">
            <form string="Fulfilment Order Line">
                <sheet>
                    <group>
                        <group>
                            <field name="order_id" />
                            <field name="product_id" />
                        </group>
                        <group>
                            <field name="quantity" />
                            <field name="unit_price" />
                            <field name="total_amount" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fulfillment_order_lines_view_list" model="ir.ui.view">
        <field name="name">fulfillment.order.lines.list</field>
        <field name="model">fulfillment.order.lines</field>
        <field name="arch" type="xml">
            <list string="Fulfilment Order Lines">
                <field name="order_id" />
                <field name="product_id" />
                <field name="quantity" />
                <field name="unit_price" />
                <field name="total_amount" />
            </list>
        </field>
    </record>

    <record id="fulfillment_order_lines_action" model="ir.actions.act_window">
        <field name="name">Fulfilment Order Lines</field>
        <field name="res_model">fulfillment.order.lines</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>

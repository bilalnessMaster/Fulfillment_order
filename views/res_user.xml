<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_users_form_inherit_fulfillment" model="ir.ui.view">
        <field name="name">res.users.form.inherit.fulfillment</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='preferences']" position="after">
                <page string="Fulfillment">
                    <group>
                        <field name="fulfillment_role" />
                        <field name="fulfilment_pos_id" />
                    </group>
                    <group>
                        <field name="fulfillment_location_ids" widget="many2many_tags" />
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>

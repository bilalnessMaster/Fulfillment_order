<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="fulfillment_pos_view_form" model="ir.ui.view">
        <field name="name">fulfillment.pos.form</field>
        <field name="model">fulfillment.pos</field>
        <field name="arch" type="xml">
            <form string="Fulfilment POS">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="POS Name" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="active" />
                            <field name="website_link" />
                        </group>
                        <group>
                            <field name="warehouse_ids" widget="many2many_tags" />
                            <field name="sequence_order_id" />
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Description..." />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="fulfillment_pos_view_list" model="ir.ui.view">
        <field name="name">fulfillment.pos.list</field>
        <field name="model">fulfillment.pos</field>
        <field name="arch" type="xml">
            <list string="Fulfilment POS">
                <field name="name" />
                <field name="active" />
                <field name="website_link" />
                <field name="warehouse_ids" widget="many2many_tags" />
            </list>
        </field>
    </record>

    <record id="fulfillment_pos_action" model="ir.actions.act_window">
        <field name="name">Fulfilment POS</field>
        <field name="res_model">fulfillment.pos</field>
        <field name="view_mode">list,form,kanban</field>
    </record>

</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="fulfillment_order.carte_item">
        <div class="flex items-start gap-3 py-3 border-b border-[#D1C3CA]/25 last:border-b-0 ">

            <!-- icon / thumbnail -->
            <div class="w-10 h-10 rounded border border-[#D1C3CA] bg-gray-100 flex items-center justify-center overflow-hidden shrink-0">
                <img t-if="props.product.image_1920" t-att-src="'data:image/png;base64,' + props.product.image_1920" t-att-alt="props.product.name" class="w-full h-full object-cover" />
            </div>

            <!-- details -->
            <div class="flex-1 min-w-0">
                <div class="flex items-start justify-between gap-2">
                    <h4 class="text-sm font-bold text-gray-900 truncate" t-esc="props.product['name']" />
                    <span class="text-sm font-bold text-gray-900 whitespace-nowrap">
                        <t t-esc="props.product['list_price'].toFixed(2)  + ' MAD'" />
                    </span>
                </div>

                <p class="text-xs text-gray-400 mt-0.5">
                    <t t-esc="props.product['quantity']" /> x <t t-esc="props.product['list_price'].toFixed(2) + 'MAD'" />
                </p>

                <div class="flex items-center gap-3 mt-2">
                    <div class="flex items-center border border-[#D1C3CA] rounded  overflow-hidden">
                        <button t-on-click="() => props.decrement(props.product)" class="w-6 h-6  border-r border-[#D1C3CA] flex items-center justify-center text-gray-500 hover:bg-gray-50 cursor-pointer">-</button>
                        <span class="w-7 text-center text-xs font-semibold text-indigo-600" t-esc="props.product['quantity']" />
                        <button t-on-click="() => props.increment(props.product)" class="w-6 h-6 flex border-l border-[#D1C3CA] items-center justify-center text-gray-500 hover:bg-gray-50 cursor-pointer">+</button>
                    </div>
                    <button t-on-click="() => props.remove(props.product)" class="text-xs font-semibold text-red-500 underline decoration-red-300 hover:text-red-600 cursor-pointer">Remove</button>
                </div>
            </div>

        </div>
    </t>
</templates>
<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="fulfillment_order.sales_product_card">
        <div class="flex flex-col  bg-white rounded border border-[#D1C3CA] overflow-hidden hover:shadow-sm transition-shadow">

            <!-- image -->
            <div class="h-40 w-full bg-gray-50">
                <img t-att-src="'data:image/png;base64,' + props.product.image_1920" t-att-alt="props.product.name" class="w-full h-full object-cover" />
            </div>

            <!-- info -->
            <div class="flex flex-col gap-1 px-4 pt-3 pb-4">
                <h3 class="text-sm  text-gray-900 truncate" t-esc="props.product.name" />
                <p class="text-xs text-gray-400">
                    SKU: <span t-esc="props.product.default_code" />
                </p>

                <div class="flex items-center justify-between mt-2">
                    <span class="text-lg font-bold text-[#57344F]">
                        <t t-esc="props.product.list_price.toFixed(2) + ' MAD'" />
                    </span>

                    <button t-on-click="() => props.onAddToCart(props.product)" title="Add to cart" class="flex items-center justify-center w-9 h-9 rounded bg-[#DCE9FF] text-indigo-600 hover:bg-indigo-600 hover:text-white transition-colors cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                        </svg>
                    </button>
                </div>
            </div>

        </div>
    </t>
</templates>
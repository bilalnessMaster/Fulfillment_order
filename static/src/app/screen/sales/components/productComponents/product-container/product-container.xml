<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="fulfillment_order.sales_products_container">
        <!-- <SalesNavbar /> -->
        <div class="grid lg:grid-cols-6 md:grid-cols-4 gap-2 p-2">
            <t t-foreach="this.state.products" t-as="product" t-key="product['id']">
                <ProductCard t-props="{
                    product: product,
                    onAddToCart: () => this.cart.addToCart(product),
                }" />
            </t>
        </div>
    </t>
</templates>
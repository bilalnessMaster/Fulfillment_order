<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="fulfillment_order.customer_create">
        <div t-if="this.customerStore.isCreateOpen" class="fixed inset-0 z-50 backdrop-blur-sm bg-black/20 flex items-center justify-center px-4">
            <div class="flex flex-col w-full max-w-xl bg-white rounded  overflow-hidden">

                <!-- header -->
                <div class="flex items-start justify-between px-5 pt-4 pb-3 border-b-2 border-[#D1C3CA]">
                    <div>
                        <h1 class="text-lg  text-gray-900">Add New Customer</h1>
                        <p class="text-xs text-gray-400 mt-0.5">Enter details to create a new profile.</p>
                    </div>
                    <button t-on-click="() => this.customerStore.setCreateOpen(false)" class="text-gray-400 hover:text-gray-700 cursor-pointer mt-0.5">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
                        </svg>
                    </button>
                </div>

                <!-- form -->
                <div class="flex flex-col gap-4 px-5 py-4">

                    <!-- full name -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs  text-gray-700 tracking-wide">FULL NAME</label>
                        <div class="relative flex items-center">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-400 absolute left-3 pointer-events-none">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                            <input type="text" placeholder="e.g. Johnathan Doe" t-att-value="this.customerStore.newCustomer['name']" t-on-input="(ev) => this.customerStore.updateNewCustomer('name', ev.target.value)" class="text-sm bg-white border border-gray-600  pl-9 pr-3 py-2.5 w-full text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500" />
                        </div>
                    </div>

                    <!-- phone + facebook -->
                    <div class="flex items-start gap-3">
                        <div class="flex flex-col gap-1.5 w-1/2">
                            <label class="text-xs  text-gray-700 tracking-wide">PHONE NUMBER</label>
                            <div class="relative flex items-center">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-400 absolute left-3 pointer-events-none">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
                                </svg>
                                <input type="text" placeholder="+1 (555) 000-0000" t-att-value="this.customerStore.newCustomer['phone']" t-on-input="(ev) => this.customerStore.updateNewCustomer('phone', ev.target.value)" class="text-sm bg-white border border-gray-600  pl-9 pr-3 py-2.5 w-full text-gray-700 placeholder-gray-400 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500" />
                            </div>
                        </div>

                        <div class="flex flex-col gap-1.5 w-1/2">
                            <label class="text-xs text-gray-700 tracking-wide">LOCATION</label>

                            <select t-att-value="this.customerStore.newCustomer['city']" t-on-change="(ev) => this.customerStore.updateNewCustomer('city', ev.target.value)" class="text-sm bg-white border border-gray-600 px-3 py-2.5 w-full text-gray-700 focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500">
                                <option value="" disabled="true" selected="true">Select location...</option>
                                <option value="agadir">Agadir</option>
                                <option value="temara">Temara</option>
                                <option value="tanger">Tanger</option>
                                <option value="marrakech">Marrakech</option>
                                <option value="casablanca">Casablanca</option>
                                <option value="nador">Nador</option>
                                <option value="fes">Fes</option>
                                <option value="tetouan">Tetouan</option>
                                <option value="kenitra">Kenitra</option>
                                <option value="oujda">Oujda</option>
                                <option value="casa_anassi">Casa Anassi</option>
                                <option value="bricolik">bricolik</option>
                                <option value="meknes">Meknès</option>
                                <option value="el_jadida">El Jadida</option>
                                <option value="ain_iti">ain iti</option>
                                <option value="depot">Dépôt</option>
                            </select>
                        </div>
                    </div>

                    <!-- delivery address -->
                    <div class="flex flex-col gap-1.5">
                        <label class="text-xs  text-gray-700 tracking-wide">DELIVERY ADDRESS</label>
                        <div class="relative flex items-start">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-gray-400 absolute left-3 top-3 pointer-events-none">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                            </svg>
                            <textarea placeholder="Street name, Building, City, ZIP Code" rows="3" t-att-value="this.customerStore.newCustomer['address']" t-on-input="(ev) => this.customerStore.updateNewCustomer('address', ev.target.value)" class="text-sm bg-white border border-gray-600  pl-9 pr-3 py-2.5 w-full text-gray-700 placeholder-gray-400 resize-none focus:outline-none focus:ring-1 focus:ring-indigo-500 focus:border-indigo-500" />
                        </div>
                    </div>

                    <!-- info note -->
                    <div class="flex items-start gap-2 bg-indigo-50 rounded-lg px-3 py-2.5">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-indigo-400 shrink-0 mt-0.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z" />
                        </svg>
                        <span class="text-xs text-indigo-900">New customers are automatically synced to the main ERP database.</span>
                    </div>
                    <!-- message -->
                    <div t-if="this.customerStore.message_after_request" class="flex items-start gap-2 bg-neutral-100 rounded-lg px-3 py-2.5">
                        <!-- <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-green-400 shrink-0 mt-0.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0Z" />
                        </svg> -->
                        <span class="text-xs text-neutral-900" t-esc="this.customerStore.message_after_request" />
                    </div>
                </div>

                <!-- footer -->
                <div class="flex items-center justify-end gap-3 bg-indigo-50/60 px-5 py-3 border-t-2 border-[#D1C3CA]">
                    <button t-on-click="() => this.customerStore.setCreateOpen(false)" class="text-sm font-semibold text-gray-500 hover:text-gray-700 px-3 py-2 cursor-pointer">Cancel</button>
                    <button t-on-click="() => this.customerStore.saveNewCustomer()" class="flex items-center gap-1.5 text-sm font-semibold text-white bg-[#4a1d3d]  p-4 py-2.5 hover:bg-[#3a1730] cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h13.5v13.5a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 16.5V3Zm0 0 3.75 3.75M3 3l3.75-3.75M16.5 3H21v4.5M21 3l-3.75 3.75M8.25 9.75h4.5v4.5h-4.5v-4.5Z" />
                        </svg>
                        Save Customer
                    </button>
                </div>

            </div>
        </div>
    </t>
</templates>
<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="fulfillment_order.order_detail">
        <div t-if="this.orders.selectedOrder" class="h-full flex flex-col">
            <div class="flex items-center justify-between p-4 border-b border-gray-200">
                <h2 class="text-sm font-bold text-gray-900">Order Details</h2>
                <button t-on-click="closeDetail" class="p-1.5 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-full cursor-pointer transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="flex-1 overflow-y-auto p-4 flex flex-col gap-4">
                <div class="flex items-center justify-between">
                    <span class="text-sm font-bold text-gray-900" t-esc="this.orders.selectedOrder.name_order"/>
                    <div class="flex items-center gap-2">
                        <a t-attf-href="'/report/pdf/fulfillment_order.fulfillment_orders_reciept/' + this.orders.selectedOrder.id"
                           target="_blank"
                           style="text-decoration: none;"
                           class="flex items-center gap-1 px-2.5 py-1 text-xs font-medium text-indigo-600 bg-indigo-50 border border-indigo-200 rounded-lg hover:bg-indigo-100 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3.5 h-3.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                            </svg>
                            Receipt
                        </a>
                        <span class="text-[10px] font-semibold px-2.5 py-1 rounded-full border" t-attf-class="#{this.getStateColor(this.orders.selectedOrder.state)}" t-esc="this.orders.selectedOrder.state"/>
                    </div>
                </div>

                <div class="bg-gray-50 rounded-2xl p-3 flex flex-col gap-2">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase">Customer</h3>
                    <div class="flex items-center gap-2">
                        <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-xs font-bold">
                            <t t-if="this.orders.selectedOrder.customer_id?.name" t-esc="this.orders.selectedOrder.customer_id?.name?.charAt(0) || '?'"/>
                            <span t-else="">?</span>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-gray-900" t-esc="this.orders.selectedOrder.customer_id?.name || 'N/A'"/>
                            <p class="text-xs text-gray-500" t-esc="this.orders.selectedOrder.customer_id?.phone || 'N/A'"/>
                        </div>
                    </div>
                </div>

                <div class="bg-gray-50 rounded-2xl p-3 flex flex-col gap-2">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase">Info</h3>
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-500">Location</span>
                        <span class="font-medium text-gray-900" t-esc="this.orders.selectedOrder.location_id?.name || 'N/A'"/>
                    </div>
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-500">Date</span>
                        <span class="font-medium text-gray-900" t-esc="this.formatDate(this.orders.selectedOrder.order_date)"/>
                    </div>
                    <div class="flex justify-between text-xs">
                        <span class="text-gray-500">Shipping</span>
                        <span class="font-medium text-gray-900">$                            <t t-esc="(this.orders.selectedOrder.shipping_price || 0).toFixed(2)"/>
                        </span>
                    </div>
                    <div class="flex justify-between text-xs pt-1 border-t border-gray-200">
                        <span class="text-gray-500 font-semibold">Total</span>
                        <span class="font-bold text-indigo-600">$                            <t t-esc="(this.orders.selectedOrder.total_amount || 0).toFixed(2)"/>
                        </span>
                    </div>
                </div>

                <div class="flex flex-col gap-2">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase">Items (<t t-esc="this.orders.selectedOrder.order_lines?.length || 0"/>
)</h3>
                    <div class="flex flex-col gap-1.5">
                        <t t-foreach="this.orders.selectedOrder.order_lines || []" t-as="line" t-key="line['id']">
                            <div class="flex items-center justify-between bg-white border border-gray-100 rounded-xl px-3 py-2">
                                <div class="flex flex-col">
                                    <span class="text-xs font-medium text-gray-900" t-esc="'Product #' + (line.product_id?.[1] || line.product_id)"/>
                                    <span class="text-[10px] text-gray-400">
                                        <t t-esc="line.quantity"/>
 x $<t t-esc="(line.unit_price || 0).toFixed(2)"/>
                                    </span>
                                </div>
                                <span class="text-xs font-bold text-gray-700">$                                    <t t-esc="(line.total_amount || 0).toFixed(2)"/>
                                </span>
                            </div>
                        </t>
                    </div>
                </div>

                <div t-if="this.getNextStates().length > 0" class="flex flex-col gap-2 pt-2 border-t border-gray-200">
                    <h3 class="text-xs font-semibold text-gray-500 uppercase">Actions</h3>
                    <div class="flex flex-wrap gap-2">
                        <t t-foreach="this.getNextStates()" t-as="nextState" t-key="nextState">
                            <button t-on-click="() => this.transitionState(nextState)" class="px-3.5 py-1.5 text-xs font-medium rounded-xl border cursor-pointer transition-colors
                                    hover:shadow-sm" t-attf-class="#{nextState === 'cancelled' ? 'border-red-200 text-red-600 hover:bg-red-50' : 'border-indigo-200 text-indigo-600 hover:bg-indigo-50'}">
                                <t t-esc="nextState.charAt(0).toUpperCase() + nextState.slice(1)"/>
                            </button>
                        </t>
                    </div>
                </div>
            </div>
        </div>

        <div t-else="" class="h-full flex items-center justify-center p-4">
            <div class="text-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-16 h-16 text-gray-300 mx-auto mb-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
                <span class="text-gray-400 text-sm font-medium">Select an order to view details</span>
            </div>
        </div>
    </t>
</templates>
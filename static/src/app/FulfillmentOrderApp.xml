<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="fulfillment_order.FulfillmentOrderApp">
        <div class="w-full h-screen flex ">

            <Navbar />
            <div class="flex-grow-1 overflow-auto bg-light  flex-1">
                <t t-if="this.store.activeScreen === 'sales'">
                    <SalesScreen/>
                </t>
                <t t-elif="this.store.activeScreen === 'orders'">
                    <OrdersScreen/>
                </t>
            </div>
        </div>
    </t>

</templates>
